# Syntesis-ICP — Variabili d'ambiente
# Copia questo file in .env e compilalo PRIMA del deploy
# NON committare mai .env su git!

# ── Ambiente ──────────────────────────────────────────────────────────────────
# 'production' (default): il boot rifiuta valori di default insicuri
# 'development': warning non bloccanti per lavorare in locale
ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# URL completo postgres://user:password@host:port/db
DATABASE_URL=postgresql://user:SCEGLI-UNA-PASSWORD-SICURA@host:5432/syntesis

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
# Minimo 32 caratteri (64 con token_hex). Il boot fallisce se e` piu` corto.
JWT_SECRET=GENERA-UNA-CHIAVE-CASUALE-LUNGA-64-CARATTERI

# Durata della sessione utente (default 24h)
TOKEN_EXPIRE_HOURS=24

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista di origini separate da virgola. Non usare '*' con allow_credentials=True.
ALLOWED_ORIGINS=https://app.syntesis-icp.com,https://syntesis-icp.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Vecchio rate limit per user_id (endpoint autenticati). Invariato.
RATE_LIMIT_PER_HOUR=60

# Nuovo rate limit per IP (SlowAPI). Usa sintassi "N/unit":
# "10/hour", "3/minute", "100/day".
# Default globale applicato a tutti gli endpoint:
RATE_LIMIT_DEFAULT=120/hour
# Limite specifico per /api/analyze-public (endpoint pubblico non autenticato):
RATE_LIMIT_ANALYZE_PUBLIC=10/hour
# Backend di storage per SlowAPI. "memory://" basta per un singolo servizio.
# Per scalare su piu` repliche: impostare un URL redis://...
RATE_LIMIT_STORAGE=memory://

# ── Timeout analisi ICP ───────────────────────────────────────────────────────
# Secondi oltre i quali una singola analisi viene interrotta con 504.
# Serve a proteggere i worker Uvicorn da file STL malformati o troppo complessi.
ICP_TIMEOUT_SECONDS=60

# ── OAuth social login (opzionale) ────────────────────────────────────────────
# Client ID Google (Web client da Google Cloud Console).
# Se vuoto, il login Google e` disabilitato.
GOOGLE_CLIENT_ID=

# Bundle ID o Services ID Apple (da developer.apple.com).
# Se vuoto, il login Apple e` disabilitato.
# IMPORTANTE: la vecchia implementazione non verificava la firma e accettava
# qualsiasi JWT con un'email. Dalla v7.3.1 il token e` validato contro le JWK
# pubbliche Apple e APPLE_CLIENT_ID deve combaciare con il claim 'aud'.
APPLE_CLIENT_ID=
