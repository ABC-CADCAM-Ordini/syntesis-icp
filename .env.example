# Syntesis-ICP — Variabili d'ambiente
# Copia questo file in .env e compilalo PRIMA del deploy
# NON committare mai .env su git!

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=SCEGLI-UNA-PASSWORD-SICURA

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GENERA-UNA-CHIAVE-CASUALE-LUNGA-64-CARATTERI

# ── CORS ─────────────────────────────────────────────────────────────────────
# Sostituisci con il tuo dominio reale
ALLOWED_ORIGINS=https://tuodominio.it,https://www.tuodominio.it

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_HOUR=60
